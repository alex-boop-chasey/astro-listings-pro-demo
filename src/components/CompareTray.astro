---
/**
 * Floating comparison tray.
 *
 * Self-contained global overlay (mirrors ContactModal): drop <CompareTray /> in
 * once near the end of <body> on any page that renders ListingCards. Owns ALL
 * client-side compare behaviour via a delegated document click listener, so
 * cards themselves stay declarative (they only carry data-* attributes).
 *
 * Selection lives in two localStorage keys, always written together:
 *   - astro-listings-compare       → string[] of listing _ids (source of truth)
 *   - astro-listings-compare-meta  → { [id]: { title, thumb, category } }
 * The sidecar meta cache lets the tray render thumbnails on pages where the
 * card isn't present. Cap: 4. Same-category only.
 */
---

<div
  id="compare-tray"
  class="fixed inset-x-0 bottom-0 z-40 hidden border-t border-slate-200 bg-white/95 shadow-[0_-4px_20px_rgba(15,23,42,0.08)] backdrop-blur"
>
  <div class="mx-auto flex max-w-6xl items-center gap-4 px-4 py-3">
    <span class="hidden shrink-0 text-sm font-semibold text-slate-700 sm:inline">Compare</span>
    <div id="compare-thumbs" class="flex items-center gap-2 overflow-x-auto"></div>
    <div class="ml-auto flex shrink-0 items-center gap-3">
      <button
        type="button"
        data-compare-clear
        class="text-sm font-medium text-slate-500 underline transition hover:text-slate-900"
      >
        Clear
      </button>
      <a
        id="compare-go"
        href="/compare"
        class="inline-flex items-center gap-1.5 rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-700"
      >
        Compare (<span id="compare-count">0</span>)
      </a>
    </div>
  </div>
</div>

<script>
  import { iconSvg } from '../lib/listing';

  const COMPARE_KEY = 'astro-listings-compare';
  const META_KEY = 'astro-listings-compare-meta';
  const MAX = 4;

  type Meta = { title: string; thumb: string; category: string };

  function getIds(): string[] {
    try {
      const raw = localStorage.getItem(COMPARE_KEY);
      const v = raw ? JSON.parse(raw) : [];
      return Array.isArray(v) ? v : [];
    } catch {
      return [];
    }
  }

  function getMeta(): Record<string, Meta> {
    try {
      const raw = localStorage.getItem(META_KEY);
      const v = raw ? JSON.parse(raw) : {};
      return v && typeof v === 'object' ? (v as Record<string, Meta>) : {};
    } catch {
      return {};
    }
  }

  // Both keys are always written together so the meta cache can't drift from
  // the id array.
  function writeState(ids: string[], meta: Record<string, Meta>) {
    try {
      localStorage.setItem(COMPARE_KEY, JSON.stringify(ids));
      localStorage.setItem(META_KEY, JSON.stringify(meta));
    } catch {
      /* localStorage unavailable — no-op */
    }
  }

  function activeCategory(ids: string[], meta: Record<string, Meta>): string | null {
    for (const id of ids) if (meta[id]) return meta[id].category;
    return null;
  }

  const tray = document.getElementById('compare-tray');
  const thumbsEl = document.getElementById('compare-thumbs');
  const countEl = document.getElementById('compare-count');
  const goEl = document.getElementById('compare-go') as HTMLAnchorElement | null;
  const removeIcon = iconSvg('cross', 'h-3 w-3');

  function esc(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;');
  }

  function render() {
    const ids = getIds();
    const meta = getMeta();
    const cat = activeCategory(ids, meta);

    // Reflect state on every compare toggle currently on the page. Styling is
    // driven by aria-pressed / disabled Tailwind variants — we only flip the
    // attributes here.
    document.querySelectorAll<HTMLButtonElement>('[data-compare-toggle]').forEach((btn) => {
      const id = btn.dataset.id ?? '';
      const active = ids.includes(id);
      btn.setAttribute('aria-pressed', String(active));

      const label = btn.querySelector('[data-compare-label]');
      if (label) label.textContent = active ? 'Comparing' : 'Compare';

      const differentCat = !active && cat !== null && btn.dataset.category !== cat;
      const full = !active && ids.length >= MAX;
      const disabled = differentCat || full;
      btn.toggleAttribute('disabled', disabled);
      btn.title = differentCat
        ? 'You can only compare listings in the same category'
        : full
          ? 'You can compare up to 4 listings'
          : '';
    });

    if (!tray) return;
    if (ids.length === 0) {
      tray.classList.add('hidden');
      return;
    }
    tray.classList.remove('hidden');
    if (countEl) countEl.textContent = String(ids.length);
    if (goEl) goEl.href = `/compare?ids=${ids.map(encodeURIComponent).join(',')}`;

    if (thumbsEl) {
      thumbsEl.innerHTML = ids
        .map((id) => {
          const m = meta[id];
          const title = esc(m?.title ?? 'Listing');
          const inner = m?.thumb
            ? `<img src="${esc(m.thumb)}" alt="" class="h-full w-full object-cover" />`
            : `<div class="flex h-full w-full items-center justify-center bg-slate-100 text-slate-400">${iconSvg('image', 'h-4 w-4')}</div>`;
          return `<div class="relative h-12 w-16 shrink-0 overflow-hidden rounded-lg ring-1 ring-inset ring-slate-200" title="${title}">
              ${inner}
              <button type="button" data-compare-remove="${esc(id)}" aria-label="Remove ${title} from compare"
                class="absolute right-0.5 top-0.5 inline-flex h-4 w-4 items-center justify-center rounded-full bg-slate-900/80 text-white transition hover:bg-slate-900">
                ${removeIcon}
              </button>
            </div>`;
        })
        .join('');
    }
  }

  function toggle(btn: HTMLButtonElement) {
    const id = btn.dataset.id ?? '';
    if (!id) return;
    const ids = getIds();
    const meta = getMeta();
    const idx = ids.indexOf(id);
    if (idx >= 0) {
      ids.splice(idx, 1);
      delete meta[id];
    } else {
      if (ids.length >= MAX) return;
      const cat = activeCategory(ids, meta);
      if (cat !== null && btn.dataset.category !== cat) return;
      ids.push(id);
      meta[id] = {
        title: btn.dataset.title ?? '',
        thumb: btn.dataset.thumb ?? '',
        category: btn.dataset.category ?? '',
      };
    }
    writeState(ids, meta);
    render();
  }

  function removeId(id: string) {
    const ids = getIds();
    const meta = getMeta();
    const idx = ids.indexOf(id);
    if (idx >= 0) ids.splice(idx, 1);
    delete meta[id];
    writeState(ids, meta);
    render();
  }

  // Delegated: the card root is an <a>, so preventDefault stops navigation.
  document.addEventListener('click', (event) => {
    const el = event.target as HTMLElement;

    const toggleBtn = el.closest<HTMLButtonElement>('[data-compare-toggle]');
    if (toggleBtn) {
      event.preventDefault();
      event.stopPropagation();
      if (!toggleBtn.hasAttribute('disabled')) toggle(toggleBtn);
      return;
    }

    const removeBtn = el.closest<HTMLElement>('[data-compare-remove]');
    if (removeBtn) {
      event.preventDefault();
      removeId(removeBtn.getAttribute('data-compare-remove') ?? '');
      return;
    }

    if (el.closest('[data-compare-clear]')) {
      event.preventDefault();
      writeState([], {}); // clear BOTH keys
      render();
    }
  });

  // Keep tabs in sync.
  window.addEventListener('storage', (event) => {
    if (event.key === COMPARE_KEY || event.key === META_KEY) render();
  });

  render();
</script>
